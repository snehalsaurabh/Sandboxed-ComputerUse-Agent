{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@sandboxed-agent/core": ["./packages/core/src/index.ts"],
      "@sandboxed-agent/core/*": ["./packages/core/src/*"],
      "@sandboxed-agent/browser": ["./packages/browser/src/index.ts"],
      "@sandboxed-agent/browser/*": ["./packages/browser/src/*"]
    }
  }
}
